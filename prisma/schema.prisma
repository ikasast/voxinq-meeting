// Voxinq data model.
// Meeting 1 - n Transcript / MeetingSummary.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Meeting {
  id          String    @id @default(cuid())
  title       String
  description   String?   @map("description") // meta info such as the meeting's purpose/contents
  sttLanguage   String?   @map("stt_language") // this meeting's STT language "auto"|"ja"|"en" (null = settings default)
  speakerLabels String?   @map("speaker_labels") // speaker key -> display name map (stringified JSON object)
  summaryStatus String?   @map("summary_status") // minutes generation state: processing | done | error
  seriesId    String?   @map("series_id") // recurring-series membership (null = standalone)
  diarizationEmbeddings String? @map("diarization_embeddings") // per-cluster voice embeddings from the last diarization run (JSON: {"speaker0": [floats]})
  embedding      String?  @map("embedding") // unused: leftover from the removed AI (semantic) search
  embeddingModel String?  @map("embedding_model") // unused: leftover from the removed AI (semantic) search
  startedAt   DateTime  @default(now()) @map("started_at")
  endedAt     DateTime? @map("ended_at")
  deletedAt   DateTime? @map("deleted_at") // trash (soft delete). null = normal. purged after a while
  archivedAt  DateTime? @map("archived_at") // archived: hidden from the list, still searchable, kept in DB
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  transcripts Transcript[]
  summaries   MeetingSummary[]
  tags        Tag[]
  series      Series?   @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([deletedAt])
  @@index([archivedAt])
  @@index([seriesId])
  @@map("meetings")
}

// A recurring meeting series ("weekly sync" etc.). When generating minutes for a
// meeting in a series, the previous meeting's minutes are fed to the LLM as
// reference-only context so follow-up topics are interpreted correctly.
model Series {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  meetings Meeting[]

  @@map("series")
}

// User-defined meeting tags (unique by name). Many-to-many with meetings.
model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  meetings Meeting[]

  @@map("tags")
}

// Enrolled voice profiles: one mean speaker embedding (voiceprint) per named person.
// Enrolled from a diarized meeting's clusters; matched against future diarization runs
// to auto-name recurring speakers.
model SpeakerProfile {
  id              String   @id @default(cuid())
  name            String   @unique
  embedding       String // JSON float array (pyannote speaker centroid)
  sourceMeetingId String?  @map("source_meeting_id") // meeting the profile was enrolled from
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("speaker_profiles")
}

model Transcript {
  id          String   @id @default(cuid())
  meetingId   String   @map("meeting_id")
  speakerType String   @map("speaker_type") // 'self' | 'partner-0' | 'partner-1' | ...
  text        String
  createdAt   DateTime @default(now()) @map("created_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId, createdAt])
  @@map("transcripts")
}

model MeetingSummary {
  id          String   @id @default(cuid())
  meetingId   String   @map("meeting_id")
  summaryText String   @map("summary_text")
  createdAt   DateTime @default(now()) @map("created_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId, createdAt])
  @@map("meeting_summaries")
}
