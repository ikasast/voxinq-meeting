# Voxinq environment — copy to `.env` and adjust.
# `scripts/setup` does this for you and asks for DATABASE_URL.

# PostgreSQL connection string (required).
DATABASE_URL="postgresql://voxinq:PASSWORD@localhost:5432/voxinq"

# STT WebSocket URL the *browser* connects to.
# ⚠ Baked into the bundle at build time — rebuild after changing.
# Local:      ws://localhost:8000/ws
# Tailscale:  wss://<host>.<tailnet>.ts.net:8443/ws
NEXT_PUBLIC_STT_WS_URL="ws://localhost:8000/ws"

# Optional password login. Unset = open within your network.
# APP_PASSWORD="change-me"

# Secret for the auth cookie — set your own random string when using APP_PASSWORD.
# APP_SESSION_SECRET="generate-a-long-random-string"

# `tailscale` (default): non-tailnet access is login-gated.
# `lan`: any reachable client is trusted (home LAN without Tailscale).
# NETWORK_MODE="tailscale"

# Runtime app settings (Whisper model, LLM provider, minutes options, API keys)
# live in `settings.json`, editable in the UI under Settings — not here.
