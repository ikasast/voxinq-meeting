# Normalize to LF inside the repo (avoids line-ending diffs between Windows/Ubuntu)
* text=auto eol=lf

# Windows-only scripts keep CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf
*.vbs text eol=crlf

# Do not convert binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.mp3 binary
*.wav binary
