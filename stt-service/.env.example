# STT service (faster-whisper) sample configuration — passed as environment variables.
# All optional; the defaults below are what the service uses when unset.
# Note: the Whisper model is normally chosen in the app's Settings UI; the env var is a fallback.

# Model: large-v3-turbo (default) / large-v3 / medium / distil-large-v3 / small
# WHISPER_MODEL=large-v3-turbo
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE=int8_float16

# Bind address
# STT_HOST=0.0.0.0
# STT_PORT=8000

# Browser origins allowed to call this service (comma-separated). Leave unset to allow the
# usual self-hosted origins automatically: localhost, private LAN addresses, and *.ts.net
# (Tailscale). Set it explicitly to lock the service to one origin.
# STT_ALLOWED_ORIGINS=https://myhost.tailnet.ts.net,http://localhost:3000

# Recording (WAV) retention in days; protected recordings are kept.
# STT_RECORDING_RETENTION_DAYS=7

# Release the Whisper model from VRAM after this many idle seconds.
# STT_IDLE_RELEASE_SECONDS=600

# Energy-based VAD tuning (utterance segmentation)
# VAD_SILENCE_MS=700
# VAD_MAX_SEGMENT_MS=12000
# VAD_MIN_SEGMENT_MS=300
# VAD_ENERGY_THRESH=0.012
